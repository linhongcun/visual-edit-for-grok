{
  "name": "visual-edit-for-grok",
  "version": "0.7.5",
  "description": "Visual Capture for Grok — multi-terminal Grok PTY + secure Aim/Frame preview with image-paste attempts and grounded DOM context",
  "main": "electron/main.cjs",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "author": "Visual Capture for Grok",
  "productName": "Visual Capture for Grok",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5179 && VEFG_DEV=1 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "demo": "python3 -m http.server 8765 --directory demo",
    "test": "for file in test/*.test.cjs; do [ \"$file\" = \"test/electron-smoke.test.cjs\" ] || node \"$file\" || exit 1; done",
    "typecheck": "tsc --noEmit",
    "check": "npm run test && npm run typecheck && npm run build",
    "test:electron": "npm run build && node test/electron-smoke.test.cjs",
    "test:packaged": "VEFG_PACKAGED_BINARY=\"release/mac-arm64/Visual Capture for Grok.app/Contents/MacOS/Visual Capture for Grok\" node test/electron-smoke.test.cjs",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --mac dir",
    "dist": "npm run build && electron-builder --mac",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "release:preflight": "node scripts/release-preflight.cjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.local.visual-capture-for-grok",
    "productName": "Visual Capture for Grok",
    "copyright": "Copyright © Visual Capture for Grok",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "i18n/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,__tests__,docs,example,examples,man}/**",
      "!**/*.{md,map,ts}",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md}"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": "-",
      "extendInfo": {
        "NSCameraUsageDescription": "Not used — Visual Capture only screenshots the embedded preview.",
        "CFBundleDisplayName": "Visual Capture for Grok",
        "CFBundleName": "Visual Capture for Grok"
      }
    },
    "dmg": {
      "title": "Visual Capture for Grok",
      "artifactName": "Visual-Capture-for-Grok-${version}-${arch}.dmg"
    },
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "electronVersion": "43.1.0"
  }
}
